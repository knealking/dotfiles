{
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "JetBrains Mono",
  "vim_mode": false,
  "restore_on_startup": "last_session",
  "icon_theme": "Material Icon Theme",
  "theme": {
    "mode": "system",
    "light": "Github Light",
    "dark": "Github Dark Dimmed"
  },
  "agent": {
    "version": "2",
    "enabled": true,
    "button": true,
    "dock": "left",
    "default_width": 640,
    "default_height": 320,
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-latest"
    }
  },
  "language_models": {
    "openai": {
      "version": "1",
      "api_url": "https://openrouter.ai/api/v1",
      "available_models": [
        {
          "display_name": "Claude 3.7 Sonnet OR",
          "name": "anthropic/claude-3.7-sonnet",
          "max_tokens": 200000
        },
        {
          "display_name": "Claude 3.5 Sonnet OR",
          "name": "anthropic/claude-3.5-sonnet",
          "max_tokens": 200000
        },
        {
          "display_name": "DeepSeek: R1 Distill Qwen 14B (free)",
          "name": "deepseek/deepseek-r1-distill-qwen-14b:free",
          "max_tokens": 131072
        },
        {
          "display_name": "Google: Gemini Pro 2.5 Experimental (free)",
          "name": "google/gemini-2.5-pro-exp-03-25:free",
          "max_tokens": 1000000
        }
      ]
    }
  },
  "edit_predictions": {
    "mode": "subtle",
    "enabled_in_text_threads": false,
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    }
  },
  "tabs": {
    "git_status": true
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  }
}
