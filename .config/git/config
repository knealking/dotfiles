# Include GitHub configuration for repos in ~/github/
[user]
	name = knealking
	email = 50931322+knealking@users.noreply.github.com
	signingkey = 82871C29344F4FA3

# Include GitLab configuration for repos in ~/gitlab/
[includeIf "gitdir:~/repos/gitlab/"]
	path = ~/.config/git/gl_config

# Include r2d2 configuration for repos in ~/r2d2/
[includeIf "gitdir:~/repos/r2d2/"]
	path = ~/.config/git/r2d2_config

[core]
	excludesfile = ~/.config/git/ignore
	whiteSpace = error

[pull]
	rebase = false

[init]
	defaultBranch = main

[status]
	branch = true
	short = true
	showStash = true
	showUntrackedFiles = all  # show individual untracked files

[credential]
	helper = libsecret
