# Include GitHub configuration for repos in ~/github/
[includeIf "gitdir:~/repos/github/"]
    path = ~/.config/git/gh-config

# Include GitLab configuration for repos in ~/gitlab/
[includeIf "gitdir:~/repos/gitlab/"]
    path = ~/.config/git/gl-config

[core]
    excludesfile = ~/.config/git/ignore
    whiteSpace = error

[commit]
    gpgsign = true

[pull]
    rebase = false

[init]
    defaultBranch = main

[tag]
    gpgSign = true

[log]
    abbrevCommit = true  # short commits
    graphColors = blue,yellow,cyan,magenta,green,red

[status]
    branch = true
    short = true
    showStash = true
    showUntrackedFiles = all  # show individual untracked files