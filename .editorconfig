# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
indent_style = space
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C/C++ files
[*.{c,h,cpp,hpp,cc,cxx}]
indent_style = space
indent_size = 4
tab_width = 4

# Python files
[*.{py}]
indent_style = space
indent_size = 4
tab_width = 4

# Makefiles
[Makefile]
indent_style = tab

# Markdown files
[*.md]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 4
